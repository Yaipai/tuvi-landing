---
export const prerender = false;

// ⚠️ MODO MANTENIMIENTO (9-may-2026)
// La home está sirviendo SOLO una página "Volvemos pronto" mientras pulimos.
// El trabajo completo (4 ejes + FAQ teaser) sigue en git en commits previos
// y en los componentes Eje*.astro / FaqTeaser.astro intactos. Para revertir:
// `git revert <hash de este commit>` y redeploy con wrangler.
// Pendientes a aplicar antes de reabrir: ver memo project_landing_coming_soon.

import Base from '../layouts/Base.astro';
import ComingSoon from '../components/ComingSoon.astro';
import LocaleSelector from '../components/LocaleSelector.astro';
import Footer from '../components/Footer.astro';
import { pickLocale } from '../i18n/pickLocale';

const acceptLanguage = Astro.request.headers.get('accept-language');
const country = (Astro.locals as any).runtime?.cf?.country as string | undefined;
const locale = pickLocale(acceptLanguage, country);

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
Astro.response.headers.set('Vary', 'Accept-Language, CF-IPCountry');
---

<Base locale={locale}>
  <header class="max-w-landing mx-auto px-6 py-4 flex justify-between items-center">
    <span class="font-bold text-xl text-tuvi-primary">Tuvi</span>
    <LocaleSelector current={locale} />
  </header>
  <ComingSoon locale={locale} />
  <Footer locale={locale} />
</Base>
