---
// ⚠️ MODO MANTENIMIENTO (9-may-2026) — ver comentario en src/pages/index.astro
import Base from '../../layouts/Base.astro';
import ComingSoon from '../../components/ComingSoon.astro';
import LocaleSelector from '../../components/LocaleSelector.astro';
import Footer from '../../components/Footer.astro';
import { SUPPORTED_LOCALES, type Locale } from '../../i18n/locales';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
---

<Base locale={locale}>
  <header class="max-w-landing mx-auto px-6 py-4 flex justify-between items-center">
    <span class="font-bold text-xl text-tuvi-primary">Tuvi</span>
    <LocaleSelector current={locale} />
  </header>
  <ComingSoon locale={locale} />
  <Footer locale={locale} />
</Base>
