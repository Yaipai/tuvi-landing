---
import { marked } from 'marked';
import Base from '../../../layouts/Base.astro';
import LocaleSelector from '../../../components/LocaleSelector.astro';
import Footer from '../../../components/Footer.astro';
import { SUPPORTED_LOCALES, type Locale } from '../../../i18n/locales';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const modules = import.meta.glob<string>('../../../content/legal-privacy/*.md', {
  eager: true,
  query: '?raw',
  import: 'default',
});

const raw =
  Object.entries(modules).find(([path]) => path.endsWith(`/${locale}.md`))?.[1] ??
  Object.entries(modules).find(([path]) => path.endsWith('/es.md'))?.[1] ??
  '';

const html = await marked.parse(String(raw));
---

<Base locale={locale} pathWithinLocale="/legal/privacy/">
  <header class="max-w-landing mx-auto px-6 py-4 flex justify-between items-center">
    <a href={`/${locale}/`} class="font-bold text-xl text-tuvi-primary">Tuvi</a>
    <LocaleSelector current={locale} />
  </header>
  <article class="prose mx-auto px-6 py-8 max-w-3xl" set:html={html} />
  <Footer locale={locale} />
</Base>
