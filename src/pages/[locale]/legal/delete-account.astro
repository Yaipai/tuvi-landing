const pageTitle = T.pageTitle[locale];
---

<Base locale={locale} pathWithinLocale="/legal/delete-account/" noindex={true}>
  <header class="max-w-landing mx-auto px-6 py-4 flex justify-between items-center">
    <a href={`/${locale}/`} class="font-bold text-xl text-tuvi-primary">Tuvi</a>
    <LocaleSelector current={locale} />
  </header>

  <article class="prose mx-auto px-6 py-8 max-w-3xl">
    <h1>{pageTitle}</h1>
    <p>{T.intro[locale]}</p>

    <h2>{T.whatDeletedHeading[locale]}</h2>
    <ul>
      {T.whatDeletedItems[locale].map((item) => <li>{item}</li>)}
    </ul>

    <h2>{T.whatKeptHeading[locale]}</h2>
    <ul>
      {T.whatKeptItems[locale].map((item) => <li>{item}</li>)}
    </ul>

    <p><strong>{T.deadline[locale]}</strong></p>

    <h2>{T.formHeading[locale]}</h2>

    <form
      id="delete-account-form"
      class="not-prose flex flex-col gap-4 border border-tuvi-border rounded-lg p-6 my-6 bg-white"
      data-support-email={SUPPORT_EMAIL}
      data-subject-prefix={T.mailSubjectPrefix[locale]}
      data-body-account={T.mailBodyAccountLine[locale]}
      data-body-reason={T.mailBodyReasonLine[locale]}
      data-body-confirm={T.mailBodyConfirmLine[locale]}
      data-validation-confirm={T.validationConfirm[locale]}
      data-validation-email={T.validationEmail[locale]}
    >
      <div class="flex flex-col gap-1">
        <label for="account-email" class="text-sm font-medium">
          {T.emailLabel[locale]} <span aria-hidden="true">*</span>
        </label>
        <input
          id="account-email"
          name="account-email"
          type="email"
          required
          placeholder={T.emailPlaceholder[locale]}
          class="border border-tuvi-border rounded px-3 py-2 text-base"
          autocomplete="email"
        />
      </div>

      <div class="flex flex-col gap-1">
        <label for="reason" class="text-sm font-medium">{T.reasonLabel[locale]}</label>
        <textarea
          id="reason"
          name="reason"
          maxlength="500"
          rows="4"
          placeholder={T.reasonPlaceholder[locale]}
          class="border border-tuvi-border rounded px-3 py-2 text-base resize-y"
        ></textarea>
      </div>

      <label class="flex items-start gap-2 text-sm">
        <input
          id="confirm-owner"
          name="confirm-owner"
          type="checkbox"
          required
          class="mt-1"
        />
        <span>{T.confirmLabel[locale]} <span aria-hidden="true">*</span></span>
      </label>

      <button
        type="submit"
        class="bg-tuvi-primary text-white font-semibold rounded px-4 py-3 hover:opacity-90 transition"
      >
        {T.submitLabel[locale]}
      </button>

      <p class="text-xs text-tuvi-text-secondary">
        {T.mailHint[locale]}{' '}
        <a href={`mailto:${SUPPORT_EMAIL}`} class="underline">{SUPPORT_EMAIL}</a>.
        {' '}{T.mailFallback[locale]}{' '}
        <a href={`mailto:${SUPPORT_EMAIL}`} class="underline">{SUPPORT_EMAIL}</a>.
      </p>
    </form>
  </article>

  <Footer locale={locale} />
</Base>

<script>
  // Compose mailto: link from form fields. Progressive enhancement: si JS está
  // desactivado, el botón hace submit estándar pero el form no tiene `action`
  // — el párrafo de fallback enseña la dirección de soporte en texto plano.
  const form = document.getElementById('delete-account-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const emailInput = form.querySelector<HTMLInputElement>('#account-email');
      const reasonInput = form.querySelector<HTMLTextAreaElement>('#reason');
      const confirmInput = form.querySelector<HTMLInputElement>('#confirm-owner');

      const email = emailInput?.value.trim() ?? '';
      const reason = reasonInput?.value.trim() ?? '';
      const confirmed = confirmInput?.checked ?? false;

      if (!email) {
        alert(form.dataset.validationEmail);
        emailInput?.focus();
        return;
      }
      if (!confirmed) {
        alert(form.dataset.validationConfirm);
        confirmInput?.focus();
        return;
      }

      const supportEmail = form.dataset.supportEmail ?? '';
      const subjectPrefix = form.dataset.subjectPrefix ?? '';
      const subject = `${subjectPrefix} - ${email}`;

      const bodyParts = [
        `${form.dataset.bodyAccount ?? ''} ${email}`,
        '',
        reason ? `${form.dataset.bodyReason ?? ''} ${reason}` : '',
        reason ? '' : '',
        form.dataset.bodyConfirm ?? '',
      ].filter((s) => s !== null);

      const body = bodyParts.join('\n');
      const href = `mailto:${supportEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = href;
    });
  }
</script>
