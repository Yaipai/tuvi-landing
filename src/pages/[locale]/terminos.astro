---
import Base from '../../layouts/Base.astro';
import LocaleSelector from '../../components/LocaleSelector.astro';
import Footer from '../../components/Footer.astro';
import { SUPPORTED_LOCALES, type Locale } from '../../i18n/locales';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const modules = import.meta.glob('../../content/legal-terms/*.md', { eager: true, query: '?raw', import: 'default' });
const file = modules[`/src/content/legal-terms/${locale}.md`] ?? modules[`/src/content/legal-terms/es.md`];
const html = String(file ?? '');
---

<Base locale={locale} pathWithinLocale="/terminos/">
  <header class="max-w-landing mx-auto px-6 py-4 flex justify-between items-center">
    <a href={`/${locale}/`} class="font-bold text-xl text-tuvi-primary">Tuvi</a>
    <LocaleSelector current={locale} />
  </header>
  <article class="prose mx-auto px-6 py-8 max-w-3xl whitespace-pre-wrap" set:html={html} />
  <Footer locale={locale} />
</Base>
