---
// ⚠️ MODO MANTENIMIENTO (9-may-2026) — FAQ redirige a la home del locale
// mientras la home está en "Volvemos pronto". El contenido real vive en el
// commit anterior.
import { SUPPORTED_LOCALES, type Locale } from '../../i18n/locales';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
return Astro.redirect(`/${locale}/`, 302);
---
