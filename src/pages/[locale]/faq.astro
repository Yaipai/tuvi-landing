---
// ⚠️ MODO MANTENIMIENTO (9-may-2026) — FAQ redirige a home del locale
// mientras la home está en "Volvemos pronto". Contenido real en commit a5ea62e.
import { SUPPORTED_LOCALES, type Locale } from '../../i18n/locales';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
return Astro.redirect(`/${locale}/`, 302);
---
