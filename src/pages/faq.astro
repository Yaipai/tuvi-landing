---
export const prerender = false;

import Base from '../layouts/Base.astro';
import LocaleSelector from '../components/LocaleSelector.astro';
import Footer from '../components/Footer.astro';
import StoreBadges from '../components/StoreBadges.astro';
import { t } from '../i18n/ui-strings';
import { pickLocale } from '../i18n/pickLocale';

const acceptLanguage = Astro.request.headers.get('accept-language');
const country = (Astro.locals as any).runtime?.cf?.country as string | undefined;
const locale = pickLocale(acceptLanguage, country);

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
Astro.response.headers.set('Vary', 'Accept-Language, CF-IPCountry');

const sections = [
  {
    id: 'trial',
    titleKey: 'faq.cat1_title' as const,
    items: [
      { qKey: 'faq.q_trial_days' as const, aKey: 'faq.a_trial_days' as const },
      { qKey: 'faq.q_trial_card' as const, aKey: 'faq.a_trial_card' as const },
      { qKey: 'faq.q_cancel' as const, aKey: 'faq.a_cancel' as const },
    ],
  },
  {
    id: 'fit',
    titleKey: 'faq.cat2_title' as const,
    items: [
      { qKey: 'faq.q_stages' as const, aKey: 'faq.a_stages' as const },
      { qKey: 'faq.q_subjects' as const, aKey: 'faq.a_subjects' as const },
      { qKey: 'faq.q_region' as const, aKey: 'faq.a_region' as const },
      { qKey: 'faq.q_uk_cambridge' as const, aKey: 'faq.a_uk_cambridge' as const },
      { qKey: 'faq.q_languages' as const, aKey: 'faq.a_languages' as const },
    ],
  },
  {
    id: 'product',
    titleKey: 'faq.cat3_title' as const,
    items: [
      { qKey: 'faq.q_platform' as const, aKey: 'faq.a_platform' as const },
      { qKey: 'faq.q_caps' as const, aKey: 'faq.a_caps' as const },
      { qKey: 'faq.q_edit' as const, aKey: 'faq.a_edit' as const },
      { qKey: 'faq.q_pdf' as const, aKey: 'faq.a_pdf' as const },
    ],
  },
  {
    id: 'schools',
    titleKey: 'faq.cat4_title' as const,
    items: [
      { qKey: 'faq.q_student_data' as const, aKey: 'faq.a_student_data' as const },
      { qKey: 'faq.q_ownership' as const, aKey: 'faq.a_ownership' as const },
      { qKey: 'faq.q_school_contract' as const, aKey: 'faq.a_school_contract' as const },
    ],
  },
  {
    id: 'plans',
    titleKey: 'faq.cat5_title' as const,
    items: [
      { qKey: 'faq.q_choose_plan' as const, aKey: 'faq.a_choose_plan' as const },
      { qKey: 'faq.q_change_plan' as const, aKey: 'faq.a_change_plan' as const },
      { qKey: 'faq.q_short_mid_month' as const, aKey: 'faq.a_short_mid_month' as const },
      { qKey: 'faq.q_annual' as const, aKey: 'faq.a_annual' as const },
      { qKey: 'faq.q_free_expires' as const, aKey: 'faq.a_free_expires' as const },
    ],
  },
];
---

<Base locale={locale} pathWithinLocale="/faq">
  <header class="max-w-landing mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="font-bold text-xl text-tuvi-primary">Tuvi</a>
    <LocaleSelector current={locale} />
  </header>

  <section class="max-w-3xl mx-auto px-6 py-10 md:py-14 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-tuvi-text-primary">
      {t('faq.page_title', locale)}
    </h1>
    <p class="mt-4 text-tuvi-text-secondary">
      {t('faq.page_subtitle', locale)}
    </p>
  </section>

  <main class="max-w-3xl mx-auto px-6 pb-12 space-y-12">
    {sections.map((section) => (
      <section id={section.id} class="scroll-mt-20">
        <h2 class="text-xl md:text-2xl font-bold text-tuvi-primary border-b border-tuvi-border pb-2">
          {t(section.titleKey, locale)}
        </h2>
        <div class="mt-6 space-y-6">
          {section.items.map((item) => (
            <details class="group border border-tuvi-border rounded-lg bg-white">
              <summary class="cursor-pointer px-4 py-3 font-semibold text-tuvi-text-primary list-none flex justify-between items-center">
                <span>{t(item.qKey, locale)}</span>
                <span class="ml-4 text-tuvi-primary text-xl group-open:rotate-45 transition-transform">+</span>
              </summary>
              <div class="px-4 pb-4 text-tuvi-text-primary leading-relaxed border-t border-tuvi-border pt-3">
                {t(item.aKey, locale)}
              </div>
            </details>
          ))}
        </div>
      </section>
    ))}

    <section class="text-center pt-6">
      <p class="text-tuvi-text-secondary">
        <a href="mailto:info@tuvi.education" class="text-tuvi-primary hover:underline">
          {t('faq.bottom_cta', locale)}
        </a>
      </p>
      <div class="mt-8">
        <StoreBadges locale={locale} />
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</Base>
