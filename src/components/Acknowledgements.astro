---
import { t } from '../i18n/ui-strings';
import type { Locale } from '../i18n/locales';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="border-t border-tuvi-border bg-tuvi-surface">
  <div class="max-w-3xl mx-auto px-6 py-10 md:py-12">
    <h2 class="text-sm font-semibold text-tuvi-primary uppercase tracking-wide text-center">
      {t('acks.heading', locale)}
    </h2>
    <p class="mt-4 text-xs md:text-sm text-tuvi-text-secondary leading-relaxed">
      {t('acks.attribution', locale)}
    </p>
    <p class="mt-3 text-xs md:text-sm text-tuvi-text-secondary leading-relaxed">
      {t('acks.disclaimer', locale)}
    </p>
  </div>
</section>
