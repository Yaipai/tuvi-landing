---
import { t } from '../i18n/ui-strings';
import StoreBadges from './StoreBadges.astro';
import type { Locale } from '../i18n/locales';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="max-w-landing mx-auto px-6 py-12 text-center">
  <div class="flex flex-col items-center gap-2">
    <img src="/tuvi-logo.svg" alt="Tuvi" class="h-20 w-20 md:h-24 md:w-24" />
    <span
      class="text-3xl md:text-4xl font-extrabold text-tuvi-primary"
      style="font-family: var(--font-heading);"
    >
      Tuvi
    </span>
  </div>

  <h1 class="text-3xl md:text-5xl font-bold leading-tight text-tuvi-text-primary mt-10 max-w-3xl mx-auto">
    {t('hero.headline', locale)}
  </h1>

  <p class="mt-6 text-lg text-tuvi-text-secondary max-w-2xl mx-auto">
    {t('hero.subhead', locale)}
  </p>

  <div class="mt-10">
    <StoreBadges locale={locale} />
  </div>

  <p class="mt-4 text-sm text-tuvi-text-secondary">
    {t('hero.cta_line', locale)}
  </p>
</section>
