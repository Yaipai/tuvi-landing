---
import { t } from '../i18n/ui-strings';
import StoreBadges from './StoreBadges.astro';
import type { Locale } from '../i18n/locales';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="bg-tuvi-surface border-y border-tuvi-border">
  <div class="max-w-landing mx-auto px-6 py-12 md:py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-tuvi-text-primary text-center max-w-3xl mx-auto">
      {t('eje4.title', locale)}
    </h2>

    <ul class="mt-8 max-w-3xl mx-auto space-y-4 text-tuvi-text-primary leading-relaxed">
      <li class="flex gap-3">
        <span class="text-tuvi-primary font-bold mt-0.5">·</span>
        <span>{t('eje4.bullet1', locale)}</span>
      </li>
      <li class="flex gap-3">
        <span class="text-tuvi-primary font-bold mt-0.5">·</span>
        <span>{t('eje4.bullet2', locale)}</span>
      </li>
      <li class="flex gap-3">
        <span class="text-tuvi-primary font-bold mt-0.5">·</span>
        <span>{t('eje4.bullet3', locale)}</span>
      </li>
    </ul>

    <div class="mt-10">
      <StoreBadges locale={locale} />
    </div>

    <p class="mt-4 text-sm text-tuvi-text-secondary text-center">
      <a href="mailto:info@tuvi.education" class="hover:text-tuvi-primary underline-offset-2 hover:underline">
        {t('eje4.demo_line', locale)}
      </a>
    </p>
  </div>
</section>
