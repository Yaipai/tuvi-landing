---
import { t } from '../i18n/ui-strings';
import type { Locale } from '../i18n/locales';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="max-w-landing mx-auto px-6 py-12 md:py-16">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-tuvi-text-primary text-center">
      {t('faq_teaser.title', locale)}
    </h2>
    <ul class="mt-8 space-y-3 text-tuvi-text-primary">
      <li>
        <a href="/faq#trial" class="flex gap-3 items-start hover:text-tuvi-primary underline-offset-4 hover:underline">
          <span class="text-tuvi-primary font-bold mt-0.5">→</span>
          <span>{t('faq_teaser.q1', locale)}</span>
        </a>
      </li>
      <li>
        <a href="/faq#fit" class="flex gap-3 items-start hover:text-tuvi-primary underline-offset-4 hover:underline">
          <span class="text-tuvi-primary font-bold mt-0.5">→</span>
          <span>{t('faq_teaser.q2', locale)}</span>
        </a>
      </li>
      <li>
        <a href="/faq#schools" class="flex gap-3 items-start hover:text-tuvi-primary underline-offset-4 hover:underline">
          <span class="text-tuvi-primary font-bold mt-0.5">→</span>
          <span>{t('faq_teaser.q3', locale)}</span>
        </a>
      </li>
    </ul>
    <div class="mt-8 text-center">
      <a
        href="/faq"
        class="inline-block px-5 py-2 border border-tuvi-primary text-tuvi-primary rounded-md font-medium hover:bg-tuvi-primary hover:text-white transition-colors"
      >
        {t('faq_teaser.cta', locale)} →
      </a>
    </div>
  </div>
</section>
