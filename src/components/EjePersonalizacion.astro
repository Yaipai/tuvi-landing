---
import { t } from '../i18n/ui-strings';
import type { Locale } from '../i18n/locales';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="max-w-landing mx-auto px-6 py-12 md:py-16">
  <div class="text-center max-w-3xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-tuvi-text-primary">
      {t('eje3.title', locale)}
    </h2>
    <p class="mt-4 text-tuvi-text-secondary leading-relaxed">
      {t('eje3.body', locale)}
    </p>
  </div>

  <div class="mt-8 max-w-3xl mx-auto bg-tuvi-surface rounded-xl p-5 border border-tuvi-border">
    <p class="text-tuvi-text-primary">
      {t('eje3.recipes_label', locale)}
    </p>
  </div>

  <p class="mt-6 text-tuvi-text-secondary text-center max-w-3xl mx-auto leading-relaxed">
    {t('eje3.school_method', locale)}
  </p>
</section>
